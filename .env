# Existing variables
PORT=5000

# Database configuration (your expiring Render database)
DB_HOST=your-expiring-db.render.com
DB_PORT=5432
DB_NAME=your_database_name
DB_USER=your_username
DB_PASSWORD=your_password

# Backup password (choose a strong password - this is like a master key)
BACKUP_PASSWORD=your-strong-backup-password-here

# Environment
NODE_ENV=production